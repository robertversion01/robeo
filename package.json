{
  "name": "robeo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000 --webpack",
    "dev:clean": "node scripts/clean-next-cache.mjs && npm run dev",
    "postinstall": "node scripts/patch-next-workstore.mjs",
    "build": "node scripts/patch-next-workstore.mjs && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "fix:product-images": "node scripts/fix-product-images.mjs",
    "deploy:trigger": "node scripts/trigger-vercel-deploy.mjs",
    "rotate:cron-secret": "node scripts/rotate-cron-secret.mjs",
    "db:apply-patch": "node scripts/apply-supabase-patch.mjs",
    "db:ensure-schema": "node scripts/ensure-marketplace-schema.mjs",
    "db:check-patches": "node scripts/check-supabase-patches.mjs",
    "audit:images": "node scripts/audit-image-presets.mjs",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "grant-admin": "node scripts/grant-admin-role.mjs",
    "test:wallet-release": "node scripts/run-wallet-release-e2e.mjs",
    "test:notifications": "node scripts/run-e2e-notification-pipeline.mjs",
    "reset:test-env": "node scripts/reset-test-environment.mjs",
    "reset:marketplace": "node scripts/reset-test-environment.mjs",
    "docs:pdf": "pwsh -ExecutionPolicy Bypass -File scripts/docs-to-pdf-all.ps1",
    "docs:pdf:all": "pwsh -ExecutionPolicy Bypass -File scripts/docs-to-pdf-all.ps1 -IncludeRoot",
    "docs:pdf:one": "pwsh -ExecutionPolicy Bypass -File scripts/md-to-pdf.ps1"
  },
  "dependencies": {
    "@stripe/stripe-js": "^9.4.0",
    "@supabase/auth-helpers-react": "^0.15.0",
    "@supabase/supabase-js": "^2.105.3",
    "@tanstack/react-virtual": "^3.14.3",
    "@types/stripe": "^8.0.416",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.14.0",
    "next": "16.3.0-canary.8",
    "nodemailer": "^8.0.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "^17.0.8",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.3.0-canary.8",
    "pg": "^8.21.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
