{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/workers/saved-search-scan",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/workers/notification-digest",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/workers/price-watch-scan",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/workers/outbox-retry",
      "schedule": "0 */4 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
