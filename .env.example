# Project URL = csak a projekt gyökére (NE legyen /rest/v1 a végén).
# Pl.: https://abcd.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Legacy dashboard: "anon" kulcs. Új dashboard: Publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key-here

# Optional compatibility aliases
SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Stripe (production webhook signing secret = Vercel env, ne commitold)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional Stripe aliases/fallbacks
STRIPE_API_KEY=
FALLBACK_STRIPE_ACCOUNT_ID=

# App URL used by Stripe redirect URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
