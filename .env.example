# =============================================================================
# Másold át `.env.local` néven és töltsd ki (a `.env.local` nincs a gitben).
# Vercelen: Project Settings → Environment Variables (ugyanezek a nevek).
# =============================================================================

# --- Supabase (kötelező a klienshez) ---
# URL = csak a projekt gyökér, pl. https://xyzcompany.supabase.co
# NE másold be a /rest/v1/ végződést az API URL-ből.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon vagy új dashboard „Publishable” kulcs (sb_publishable_...).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key-here

# --- Supabase (opcionális aliasok / szerver) ---
# Ha NEXT_PUBLIC_* nem elérhető, néha ezeket használhatod szerveren:
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Ha csak publishable kulcsod van, ez is megfelel (a kód elfogadja):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Szerver-only: checkout/webhook, admin, seed scriptek — SOHA ne tedd NEXT_PUBLIC_-ba.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Vercel Cron + worker API-k (saved-search-scan). Vercel automatikusan küldi: Authorization: Bearer <érték>
# Hobby plan: vercel.json max 1×/nap (0 21 * * *). Óránkénti scan: GitHub Actions + ugyanitt CRON_SECRET.
CRON_SECRET=generate-a-long-random-string

# Deploy Hook fallback (Settings → Git → Deploy Hooks, branch main) — csak .env.local / GitHub Secret, ne commitold
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/prj_xxx/yyy

# Lokális Ollama (upload AI) — csak dev; éles Vercelről nem éri el a géped localhostját
NEXT_PUBLIC_OLLAMA_URL=http://127.0.0.1:11434
NEXT_PUBLIC_OLLAMA_CHAT_MODEL=llama3

# --- Stripe ---
# Secret key (sk_test_… lokálisan, sk_live_… élesben — csak szerver/Vercel).
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook aláírás ellenőrzéséhez: Stripe Dashboard → Webhooks → Signing secret (whsec_…).
# Lokálisan: `stripe listen --forward-to localhost:3000/api/stripe/webhook` más whsec-et ad.
# Ugyanitt add hozzá az eseményeket: checkout.session.completed, payment_intent.succeeded,
# payment_intent.payment_failed, charge.refunded (Vercel logokban szűrés: `[stripe-webhook]`).
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Opcionális: ha STRIPE_SECRET_KEY helyett másképp nevezed:
STRIPE_API_KEY=
# Opcionális: Connect / több fiók esetén fallback connected account ID.
FALLBACK_STRIPE_ACCOUNT_ID=

# --- App URL (Stripe redirect URL-ek, OG meta) ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- .NET Marketplace.API → PostgreSQL (TILOS a valódi jelszót commitolni) ---
# Teljes connection string env-ből (ASP.NET Core felülírja az appsettings-et):
# ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=robeo;Username=postgres;Password=YOUR_PASSWORD_HERE
#
# PowerShell (aktuális session):
#   $env:ConnectionStrings__Postgres = "Host=localhost;Port=5432;Database=robeo;Username=postgres;Password=..."
#
# User secrets (backend/src/Marketplace.API mappából):
#   dotnet user-secrets set "ConnectionStrings:Postgres" "Host=localhost;Port=5432;Database=robeo;Username=postgres;Password=..."
#
# Csak jelszó (összefűzi az appsettings connection stringhez; a `run_v2` backend script a `backend/Postgres.local.env`-ből is betölti):
#   POSTGRES_PASSWORD=your_password_here
#
# A Vercel Next.js build alapból nem olvassa ezt; csak akkor add meg a Vercelen, ha az API-t is ott futtatod / átadod env-ként.

# --- v2 előnézet (opcionális, NEM éles termék) ---
# Élesben a v2 kapcsoló rejtett. Lokálisan dev módban látszik; kényszerítéshez:
# NEXT_PUBLIC_ENABLE_V2_PREVIEW=true
# Ha a Vite nem ugyanazon a hoston fut, mint a Next (pl. fix 127.0.0.1):
# NEXT_PUBLIC_V2_URL=http://127.0.0.1:5173
